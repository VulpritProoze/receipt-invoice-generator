# BillGen Environment Configuration

# Database Configuration
# By default, SQLite is used for local development
# Set USE_REDIS=true to use Upstash Redis (for production)
USE_REDIS=false

# SQLite Database Path (optional, defaults to .dev/billgen.db)
# DATABASE_URL=.dev/billgen.db

# Upstash Redis Configuration (only needed when USE_REDIS=true)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token_here

# Next.js Configuration
# NEXT_PUBLIC_ prefix makes variables available to the browser
# Never prefix secrets with NEXT_PUBLIC_
# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Admin User Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
