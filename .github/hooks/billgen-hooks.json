{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/pretool-lint.mjs",
        "cwd": ".",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/posttool-format.mjs",
        "cwd": ".",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/stop-docs-updater.mjs",
        "cwd": ".",
        "timeout": 5
      }
    ]
  }
}